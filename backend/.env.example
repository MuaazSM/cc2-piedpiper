# Database connection string
# For local dev, SQLite is used. For production, swap to PostgreSQL.
# Example PostgreSQL: postgresql://user:password@host:5432/lorri_db
DATABASE_URL=sqlite:///./dev.db

# OpenAI API key — fallback for LangChain agents if Gemini is unavailable
OPENAI_API_KEY=your-openai-key-here

# Google Gemini API key — primary LLM for all 4 agents
# Get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here